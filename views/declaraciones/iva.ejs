<%- include('../partials/header', {title: title}) %>
<div class="page-header" style="display:flex;justify-content:space-between;">
  <div>
    <h2>Formulario 300 — IVA Bimestre <%= bimestreNombre %> 2025</h2>
    <p>Inversiones Uniatlantico S.A.S. &nbsp;|&nbsp; NIT: 900.123.456-7</p>
  </div>
  <a href="/declaraciones" class="btn btn-secondary">Volver</a>
</div>

<div class="tip-box" style="background:#EBF5FB;border-left:4px solid #2E75B6;padding:10px 14px;border-radius:0 8px 8px 0;font-size:13px;margin-bottom:1rem;">
  Valores calculados del libro de transacciones. Para presentar oficialmente ve a <a href="<%= mokanataxUrl %>/declaraciones/iva/<%= bimestre %>" target="_blank" class="btn-link">MokanaTax → Form. 300</a>
</div>

<div class="form-card">
  <div style="display:flex;align-items:center;gap:16px;padding:12px 16px;background:var(--blue);color:white;border-radius:8px;margin-bottom:1.5rem;">
    <div style="font-size:28px;font-weight:700;background:rgba(255,255,255,0.15);padding:8px 16px;border-radius:8px;">300</div>
    <div><strong>Declaración del Impuesto sobre las Ventas — IVA</strong><br>
    <small>Bimestre: <%= bimestreNombre %> 2025 — NIT: 900.123.456-7 — Inversiones Uniatlantico S.A.S.</small></div>
  </div>

  <div style="background:var(--blue-light);padding:6px 12px;border-radius:4px;font-size:12px;font-weight:600;color:var(--blue);margin:1rem 0 8px;text-transform:uppercase;">Sección ingresos</div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;">
    <span>Casilla 28 — Por operaciones gravadas a la tarifa general (19%)</span>
    <strong>$<%= Number(ivaGenerado / 0.19).toLocaleString('es-CO') %></strong>
  </div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;">
    <span>Casilla 42 — Devoluciones en ventas (notas crédito)</span>
    <strong style="color:var(--red)">($<%= Number(ivaDevoluciones).toLocaleString('es-CO') %>)</strong>
  </div>

  <div style="background:var(--blue-light);padding:6px 12px;border-radius:4px;font-size:12px;font-weight:600;color:var(--blue);margin:1rem 0 8px;text-transform:uppercase;">Impuesto generado (Casilla 67)</div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;">
    <span>Casilla 59 — IVA generado a la tarifa general (19%)</span>
    <strong>$<%= Number(ivaGenerado).toLocaleString('es-CO') %></strong>
  </div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:var(--blue-light);border-radius:4px;margin-top:8px;font-size:15px;font-weight:600;">
    <span>Total impuesto generado (Casilla 67)</span>
    <strong>$<%= Number(ivaGeneradoNeto).toLocaleString('es-CO') %></strong>
  </div>

  <div style="background:var(--blue-light);padding:6px 12px;border-radius:4px;font-size:12px;font-weight:600;color:var(--blue);margin:1rem 0 8px;text-transform:uppercase;">Impuesto descontable (Casilla 81)</div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;">
    <span>Casilla 72 — Por compras de bienes gravados a la tarifa general</span>
    <strong>$<%= Number(ivaDescontable).toLocaleString('es-CO') %></strong>
  </div>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:var(--blue-light);border-radius:4px;margin-top:8px;font-size:15px;font-weight:600;">
    <span>Total impuestos descontables (Casilla 81)</span>
    <strong>$<%= Number(ivaDescontable).toLocaleString('es-CO') %></strong>
  </div>

  <div style="background:var(--blue-light);padding:6px 12px;border-radius:4px;font-size:12px;font-weight:600;color:var(--blue);margin:1rem 0 8px;text-transform:uppercase;">Liquidación</div>
  <% if(saldoPagar > 0){ %>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:#FADBD8;border-radius:4px;font-size:16px;font-weight:700;color:var(--red);">
    <span>Casilla 82 — Saldo a pagar por el período fiscal</span>
    <strong>$<%= Number(saldoPagar).toLocaleString('es-CO') %></strong>
  </div>
  <% } else { %>
  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:var(--green-light);border-radius:4px;font-size:16px;font-weight:700;color:var(--green);">
    <span>Casilla 83 — Saldo a favor del período fiscal</span>
    <strong>$<%= Number(saldoFavor).toLocaleString('es-CO') %></strong>
  </div>
  <% } %>

  <div style="margin-top:1.5rem;padding:12px;background:var(--gray);border-radius:8px;font-size:13px;">
    <strong>Próximo paso:</strong> Lleva estos valores a MokanaTax para presentar la declaración oficial con número de radicado.
    <a href="<%= mokanataxUrl %>/declaraciones/iva/<%= bimestre %>" target="_blank" class="btn btn-primary" style="margin-left:10px;padding:4px 14px;font-size:12px;">Ir a MokanaTax →</a>
  </div>
</div>
<%- include('../partials/footer') %>
