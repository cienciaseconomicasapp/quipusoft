<%- include('../partials/header', {title: title}) %>
<div class="page-header" style="display:flex;justify-content:space-between;">
  <div>
    <h2>Formulario 350 — Retención en la Fuente <%= mesNombre %> 2025</h2>
    <p>Inversiones Uniatlantico S.A.S. &nbsp;|&nbsp; NIT: 900.123.456-7</p>
  </div>
  <a href="/declaraciones" class="btn btn-secondary">Volver</a>
</div>

<div class="tip-box" style="background:#EBF5FB;border-left:4px solid #2E75B6;padding:10px 14px;border-radius:0 8px 8px 0;font-size:13px;margin-bottom:1rem;">
  Valores calculados del libro de transacciones de <%= mesNombre %> 2025. UVT 2025: $<%= Number(UVT_2025).toLocaleString('es-CO') %>.
  Para presentar oficialmente: <a href="<%= mokanataxUrl %>/declaraciones/retencion/<%= mes %>" target="_blank" class="btn-link">MokanaTax → Form. 350</a>
</div>

<div class="form-card">
  <div style="display:flex;align-items:center;gap:16px;padding:12px 16px;background:var(--blue);color:white;border-radius:8px;margin-bottom:1.5rem;">
    <div style="font-size:28px;font-weight:700;background:rgba(255,255,255,0.15);padding:8px 16px;border-radius:8px;">350</div>
    <div><strong>Declaración Mensual de Retenciones en la Fuente</strong><br>
    <small>Período: <%= mesNombre %> 2025 — NIT: 900.123.456-7</small></div>
  </div>

  <div style="background:var(--blue-light);padding:6px 12px;border-radius:4px;font-size:12px;font-weight:600;color:var(--blue);margin:1rem 0 8px;text-transform:uppercase;">
    Retenciones practicadas a personas jurídicas — Título de renta
  </div>

  <% if(conceptos.length === 0){ %>
    <p style="color:var(--muted);padding:1rem;text-align:center;">No hay retenciones registradas para <%= mesNombre %> 2025.</p>
  <% } %>

  <% conceptos.forEach(c => { %>
  <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;">
    <span><%= c.concepto_agrupado %></span>
    <span style="color:var(--muted);font-size:12px;">Base: $<%= Number(c.base_total||0).toLocaleString('es-CO') %></span>
    <strong>$<%= Number(c.total_retencion||0).toLocaleString('es-CO') %></strong>
  </div>
  <% }) %>

  <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:#FADBD8;border-radius:4px;margin-top:8px;font-size:16px;font-weight:700;color:var(--red);">
    <span>Casilla 130 — Total retenciones renta y complementario</span>
    <strong>$<%= Number(totalRetencion).toLocaleString('es-CO') %></strong>
  </div>

  <div style="margin-top:1.5rem;padding:12px;background:var(--gray);border-radius:8px;font-size:13px;">
    <strong>Próximo paso:</strong> Lleva estos valores a MokanaTax para presentar la declaración oficial.
    <a href="<%= mokanataxUrl %>/declaraciones/retencion/<%= mes %>" target="_blank" class="btn btn-primary" style="margin-left:10px;padding:4px 14px;font-size:12px;">Ir a MokanaTax →</a>
  </div>
</div>
<%- include('../partials/footer') %>
