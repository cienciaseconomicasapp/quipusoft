<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
<nav class="navbar">
  <div class="navbar-brand">
    <span class="brand-icon">Q</span>
    <span class="brand-name">Quipusoft</span>
    <span class="brand-sub">Software Contable Académico</span>
  </div>
  <div class="navbar-links">
    <a href="/dashboard">Inicio</a>
    <a href="/transacciones">Transacciones</a>
    <a href="/nomina">Nómina</a>
    <a href="/declaraciones">Declaraciones</a>
    <% if(user && (user.rol === 'docente' || user.rol === 'admin')){ %>
      <a href="/admin" style="background:#8E44AD;color:white;padding:4px 12px;border-radius:6px;">Panel docente</a>
    <% } %>
    <a href="<%= mokanataxUrl %>" target="_blank" class="btn-mokanatax">Ir a MokanaTax</a>
  </div>
  <div class="navbar-user">
    <% if(user && user.foto){ %>
      <img src="<%= user.foto %>" alt="<%= user.nombre %>" class="user-avatar">
    <% } %>
    <span class="user-name"><%= user ? user.nombre.split(' ')[0] : '' %></span>
    <% if(user && (user.rol === 'docente' || user.rol === 'admin')){ %>
      <span style="font-size:10px;background:#8E44AD;color:white;padding:1px 6px;border-radius:10px;margin-right:4px;">Docente</span>
    <% } %>
    <a href="/auth/logout" class="btn-logout">Salir</a>
  </div>
</nav>
<main class="main-content">
  <% if(locals.success && success && success.length){ %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if(locals.error && error && error.length){ %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
