<%- include('../partials/header') %>
<%- include('../partials/erp-header', { icon: '🛒', title: 'Productos y Servicios' }) %>

<% if(success && success.length){ %><div class="alert alert-success" style="margin-bottom:1rem;"><%= success %></div><% } %>
<% if(error && error.length){ %><div class="alert alert-error" style="margin-bottom:1rem;"><%= error %></div><% } %>

<div class="erp-form-card">
  <div class="erp-form-card-title">Crear / editar producto o servicio</div>
  <div class="erp-form-card-note">
    Cada producto o servicio del catálogo está vinculado a sus cuentas contables. Al facturarlo, Quipusoft
    genera automáticamente el asiento (cartera, ingreso, IVA, retención y costo/inventario si aplica).
  </div>
  <form method="POST" action="/contabilidad/productos">
    <div class="erp-form-body">

      <div class="erp-form-field">
        <label>Código<span class="req">*</span></label>
        <div class="erp-field-wrap"><input class="erp-input" type="text" name="codigo" placeholder="Ej: PROD-05" required></div>
      </div>

      <div class="erp-form-field span-2">
        <label>Nombre<span class="req">*</span></label>
        <div class="erp-field-wrap"><input class="erp-input" type="text" name="nombre" placeholder="Ej: Tablets Samsung" required></div>
      </div>

      <div class="erp-form-field">
        <label>Tipo<span class="req">*</span></label>
        <div class="erp-field-wrap valid">
          <select class="erp-select" name="tipo" id="tipo" required>
            <option value="producto">Producto (con inventario)</option>
            <option value="servicio">Servicio (sin inventario)</option>
          </select>
          <span class="erp-check">✓</span>
        </div>
      </div>

      <div class="erp-form-field span-2">
        <label>Cuenta de ingreso (clase 4)<span class="req">*</span></label>
        <div class="erp-field-wrap">
          <input class="erp-input" type="text" name="cuenta_ingreso" list="lista-cuentas-prod" placeholder="Ej: 41350505" required>
        </div>
      </div>

      <div class="erp-form-field campo-producto">
        <label>Cuenta de costo (clase 6)</label>
        <div class="erp-field-wrap"><input class="erp-input" type="text" name="cuenta_costo" list="lista-cuentas-prod" placeholder="Ej: 61350505"></div>
      </div>

      <div class="erp-form-field campo-producto">
        <label>Cuenta de inventario (clase 1)</label>
        <div class="erp-field-wrap"><input class="erp-input" type="text" name="cuenta_inventario" list="lista-cuentas-prod" placeholder="Ej: 14300505"></div>
      </div>

      <datalist id="lista-cuentas-prod">
        <% cuentas.forEach(c => { %><option value="<%= c.codigo %>"><%= c.codigo %> — <%= c.nombre %></option><% }) %>
      </datalist>

      <div class="erp-form-field campo-producto">
        <label>Costo unitario</label>
        <div class="erp-field-wrap"><input class="erp-input text-right" type="number" name="costo_unitario" value="0" min="0"></div>
      </div>

      <div class="erp-form-field">
        <label>Precio de venta<span class="req">*</span></label>
        <div class="erp-field-wrap"><input class="erp-input text-right" type="number" name="precio_venta" value="0" min="0" required></div>
      </div>

      <div class="erp-form-field">
        <label>Tarifa IVA (%)</label>
        <div class="erp-field-wrap valid">
          <select class="erp-select" name="tarifa_iva">
            <option value="19">19% (Gravado)</option>
            <option value="0">0% (Exento/Excluido)</option>
          </select>
          <span class="erp-check">✓</span>
        </div>
      </div>

      <div class="erp-form-field">
        <label>Tarifa retención en la fuente (%)</label>
        <div class="erp-field-wrap"><input class="erp-input text-right" type="number" name="tarifa_retencion" value="0" min="0" step="0.1"></div>
      </div>

      <div class="erp-form-field span-2">
        <label>Concepto de retención</label>
        <div class="erp-field-wrap"><input class="erp-input" type="text" name="concepto_retencion" placeholder="Ej: Compras, Servicios, Honorarios"></div>
      </div>

    </div>
    <div class="erp-actions">
      <button type="submit" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">💾</span> Guardar producto/servicio</button>
    </div>
  </form>
</div>

<div class="erp-items-table-wrap" style="padding:0;">
<table class="erp-book-table">
  <thead><tr>
    <th style="width:80px">Código</th>
    <th>Nombre</th>
    <th class="c" style="width:80px">Tipo</th>
    <th style="width:90px">Cta. ingreso</th>
    <th style="width:90px">Cta. costo</th>
    <th style="width:90px">Cta. invent.</th>
    <th class="r" style="width:100px">Precio venta</th>
    <th class="c" style="width:60px">IVA</th>
    <th class="c" style="width:70px">Retención</th>
    <th class="c" style="width:80px">Estado</th>
    <th class="c" style="width:90px">Acción</th>
  </tr></thead>
  <tbody>
  <% productos.forEach(p => { %>
    <tr style="<%= !p.activo ? 'opacity:.5;' : '' %>">
      <td><code style="font-size:11px;"><%= p.codigo %></code></td>
      <td><%= p.nombre %></td>
      <td class="c" style="font-size:11px;text-transform:capitalize;"><%= p.tipo %></td>
      <td><code style="font-size:11px;"><%= p.cuenta_ingreso %></code></td>
      <td><code style="font-size:11px;"><%= p.cuenta_costo || '-' %></code></td>
      <td><code style="font-size:11px;"><%= p.cuenta_inventario || '-' %></code></td>
      <td class="r"><%= Number(p.precio_venta).toLocaleString('es-CO') %></td>
      <td class="c"><%= Number(p.tarifa_iva) %>%</td>
      <td class="c"><%= Number(p.tarifa_retencion) %>%</td>
      <td class="c"><%= p.activo ? '✅' : '⛔' %></td>
      <td class="c">
        <form method="POST" action="/contabilidad/productos/<%= p.codigo %>/toggle" style="display:inline;">
          <button type="submit" class="erp-btn erp-btn-outline" style="padding:3px 8px;font-size:11px;">
            <%= p.activo ? 'Inactivar' : 'Activar' %>
          </button>
        </form>
      </td>
    </tr>
  <% }) %>
  </tbody>
</table>
</div>

<script>
document.getElementById('tipo').addEventListener('change', function() {
  const esServicio = this.value === 'servicio';
  document.querySelectorAll('.campo-producto input').forEach(function(input) {
    input.required = !esServicio && (input.name === 'cuenta_costo' || input.name === 'cuenta_inventario');
  });
});
</script>

<%- include('../partials/footer') %>
