<%- include('../partials/header') %>
<div class="page-header">
  <div><h2>Libro Auxiliar</h2><p>Inversiones Uniatlantico S.A.S. — AG 2025</p></div>
  <a href="/contabilidad" class="btn btn-secondary">← Libros</a>
</div>

<form method="GET" action="/contabilidad/libro-auxiliar" class="filtros-form">
  <div class="filtros-row">
    <div class="filtro-grupo"><label>Cuenta</label>
      <select name="cuenta" style="border:1px solid #ccc;border-radius:6px;padding:6px 10px;font-size:13px;min-width:280px;">
        <% todasCuentas.forEach(c => { %>
          <option value="<%= c.codigo %>" <%= cuentaFiltro === c.codigo ? 'selected' : '' %>><%= c.codigo %> — <%= c.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="filtro-grupo"><label>Desde</label><input type="date" name="desde" value="<%= fechaDesde %>"></div>
    <div class="filtro-grupo"><label>Hasta</label><input type="date" name="hasta" value="<%= fechaHasta %>"></div>
    <div class="filtro-grupo" style="align-self:flex-end"><button type="submit" class="btn btn-primary">Consultar</button></div>
    <div class="filtro-grupo" style="align-self:flex-end"><button type="button" onclick="window.print()" class="btn btn-secondary">🖨 Imprimir</button></div>
  </div>
</form>

<% if(cuenta){ %>
<div class="cuenta-info-bar">
  <strong><%= cuenta.codigo %> — <%= cuenta.nombre %></strong>
  &nbsp;|&nbsp; Naturaleza: <strong><%= cuenta.naturaleza === 'D' ? 'Débito' : 'Crédito' %></strong>
  &nbsp;|&nbsp; Saldo inicial al <%= new Date(fechaDesde).toLocaleDateString('es-CO') %>:
  <strong class="<%= saldoInicial >= 0 ? 'saldo-deb' : 'saldo-cred' %>">
    $<%= Math.abs(saldoInicial).toLocaleString('es-CO') %> <%= saldoInicial >= 0 ? 'D' : 'C' %>
  </strong>
</div>

<table class="tabla-auxiliar">
  <thead><tr>
    <th style="width:90px">Fecha</th>
    <th style="width:120px">Comprobante</th>
    <th>Concepto / Descripción</th>
    <th style="width:110px">Contraparte</th>
    <th style="width:120px;text-align:right">Débito</th>
    <th style="width:120px;text-align:right">Crédito</th>
    <th style="width:130px;text-align:right">Saldo</th>
  </tr></thead>
  <tbody>
    <tr class="fila-saldo-inicial">
      <td colspan="4" style="font-weight:600;font-style:italic;color:#555">Saldo anterior al período</td>
      <td></td><td></td>
      <td style="text-align:right;font-weight:700">
        $<%= Math.abs(saldoInicial).toLocaleString('es-CO') %> <%= saldoInicial >= 0 ? 'D' : 'C' %>
      </td>
    </tr>
  <% movimientos.forEach((m, i) => { %>
    <tr class="<%= i%2===0?'par':'impar' %>">
      <td><%= new Date(m.fecha).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'2-digit'}) %></td>
      <td><code style="font-size:11px"><%= m.numero_comprobante %></code></td>
      <td style="font-size:12px"><%= m.descripcion || m.concepto %></td>
      <td style="font-size:11px;color:#666"><%= m.contraparte ? m.contraparte.substring(0,25) : '' %></td>
      <td style="text-align:right;color:<%= m.debito > 0 ? '#7D4900' : '#ccc' %>;font-weight:<%= m.debito > 0 ? '600' : '400' %>">
        <%= m.debito > 0 ? '$' + Number(m.debito).toLocaleString('es-CO') : '—' %>
      </td>
      <td style="text-align:right;color:<%= m.credito > 0 ? '#1E5631' : '#ccc' %>;font-weight:<%= m.credito > 0 ? '600' : '400' %>">
        <%= m.credito > 0 ? '$' + Number(m.credito).toLocaleString('es-CO') : '—' %>
      </td>
      <td style="text-align:right;font-weight:700;color:<%= m.saldo >= 0 ? '#1F3864' : '#C0392B' %>">
        $<%= Math.abs(m.saldo).toLocaleString('es-CO') %> <%= m.saldo >= 0 ? 'D' : 'C' %>
      </td>
    </tr>
  <% }) %>
  <% if(movimientos.length > 0){ %>
    <tr class="fila-total">
      <td colspan="3" style="text-align:right;font-weight:600">TOTALES DEL PERÍODO:</td>
      <td></td>
      <td style="text-align:right;font-weight:700;color:#7D4900">
        $<%= movimientos.reduce((a,m)=>a+Number(m.debito),0).toLocaleString('es-CO') %>
      </td>
      <td style="text-align:right;font-weight:700;color:#1E5631">
        $<%= movimientos.reduce((a,m)=>a+Number(m.credito),0).toLocaleString('es-CO') %>
      </td>
      <td style="text-align:right;font-weight:700;color:#1F3864">
        <% const saldoFinal = movimientos[movimientos.length-1].saldo; %>
        $<%= Math.abs(saldoFinal).toLocaleString('es-CO') %> <%= saldoFinal >= 0 ? 'D' : 'C' %>
      </td>
    </tr>
  <% } %>
  </tbody>
</table>
<% } else { %>
<div class="tip-box">Selecciona una cuenta para ver su auxiliar.</div>
<% } %>

<style>
.filtros-form { background:#f5f7fa;border:1px solid #ddd;border-radius:8px;padding:12px 16px;margin-bottom:1rem; }
.filtros-row { display:flex;gap:12px;flex-wrap:wrap;align-items:flex-start; }
.filtro-grupo { display:flex;flex-direction:column;gap:4px; }
.filtro-grupo label { font-size:12px;color:#555;font-weight:500; }
.filtro-grupo input { border:1px solid #ccc;border-radius:6px;padding:6px 10px;font-size:13px; }
.cuenta-info-bar { background:#EBF5FB;border:1px solid #2E75B6;border-radius:8px;padding:10px 16px;font-size:13px;margin-bottom:12px; }
.saldo-deb { color:#7D4900; } .saldo-cred { color:#1E5631; }
.tabla-auxiliar { width:100%;border-collapse:collapse;font-size:13px; }
.tabla-auxiliar th { background:#1F3864;color:#fff;padding:7px 10px; }
.tabla-auxiliar td { padding:5px 10px;border-bottom:1px solid #eee; }
.fila-saldo-inicial td { background:#EBF5FB; }
.par td { background:#fff; } .impar td { background:#FAFAFA; }
.fila-total td { background:#f0f0f0;border-top:2px solid #ccc; }
@media print { .filtros-form,.btn,nav,.page-header a { display:none; } }
</style>
<%- include('../partials/footer') %>
