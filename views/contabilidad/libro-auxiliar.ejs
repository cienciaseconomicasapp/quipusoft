<%- include('../partials/header') %>
<%- include('../partials/erp-header', { icon: '📘', title: 'Libros auxiliares' }) %>

<div class="erp-tabs">
  <span class="erp-tab active">Libro auxiliar</span>
</div>

<div class="erp-search-panel">
  <div class="erp-search-panel-title">Opciones de búsqueda</div>
  <form method="GET" action="/contabilidad/libro-auxiliar">
    <div class="erp-search-body">
      <div class="erp-search-row">
        <label>Cuenta contable</label>
        <div class="erp-field-wrap valid">
          <select name="cuenta" class="erp-select">
            <% todasCuentas.forEach(c => { %>
              <option value="<%= c.codigo %>" <%= cuentaFiltro === c.codigo ? 'selected' : '' %>><%= c.codigo %> — <%= c.nombre %></option>
            <% }) %>
          </select>
          <span class="erp-check">✓</span>
        </div>
      </div>
      <div class="erp-search-row erp-row-split">
        <label>Fechas</label>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="desde" value="<%= fechaDesde %>">
          <span class="erp-check">✓</span>
        </div>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="hasta" value="<%= fechaHasta %>">
          <span class="erp-check">✓</span>
        </div>
      </div>
    </div>
    <div class="erp-actions">
      <button type="submit" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">⚙</span> Mostrar libro auxiliar</button>
      <button type="button" onclick="window.print()" class="erp-btn erp-btn-teal"><span class="erp-btn-icon">🖨</span> Imprimir libro auxiliar</button>
    </div>
  </form>
</div>

<% if(cuenta){ %>
<div class="erp-book-section">
  <div class="erp-book-section-title">
    <code><%= cuenta.codigo %></code> <%= cuenta.nombre %>
    <span class="erp-badge-nat <%= cuenta.naturaleza === 'D' ? 'deb' : 'cred' %>">
      Naturaleza <%= cuenta.naturaleza === 'D' ? 'Débito' : 'Crédito' %>
    </span>
  </div>
  <table class="erp-book-table">
    <thead><tr>
      <th style="width:110px">Doc</th>
      <th style="width:90px">Fecha</th>
      <th style="width:140px">Tercero</th>
      <th>Detalle</th>
      <th class="r" style="width:130px">Débito</th>
      <th class="r" style="width:130px">Crédito</th>
      <th class="r" style="width:140px">Saldo</th>
    </tr></thead>
    <tbody>
      <tr class="erp-row-saldo-anterior">
        <td>-</td><td>-</td><td>-</td>
        <td>Saldo anterior</td>
        <td class="r"></td><td class="r"></td>
        <td class="r" style="font-weight:700;">
          <%= Math.abs(saldoInicial).toLocaleString('es-CO',{minimumFractionDigits:2}) %> <%= saldoInicial >= 0 ? 'D' : 'C' %>
        </td>
      </tr>
    <% if(movimientos.length === 0) { %>
      <tr>
        <td>-</td><td>-</td><td>-</td>
        <td>[SIN MOVIMIENTOS]</td>
        <td class="r">0.00</td><td class="r">0.00</td>
        <td class="r" style="font-weight:700;">
          <%= Math.abs(saldoInicial).toLocaleString('es-CO',{minimumFractionDigits:2}) %> <%= saldoInicial >= 0 ? 'D' : 'C' %>
        </td>
      </tr>
    <% } %>
    <% movimientos.forEach((m) => { %>
      <tr>
        <td><code style="font-size:11px"><%= m.numero_comprobante %></code></td>
        <td><%= new Date(m.fecha).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'2-digit'}) %></td>
        <td style="font-size:11.5px;color:var(--muted);"><%= m.contraparte ? m.contraparte.substring(0,28) : '-' %></td>
        <td><%= m.descripcion || m.concepto %></td>
        <td class="r <%= m.debito > 0 ? 'erp-amount-debit' : '' %>"><%= m.debito > 0 ? Number(m.debito).toLocaleString('es-CO',{minimumFractionDigits:2}) : '0.00' %></td>
        <td class="r <%= m.credito > 0 ? 'erp-amount-credit' : '' %>"><%= m.credito > 0 ? Number(m.credito).toLocaleString('es-CO',{minimumFractionDigits:2}) : '0.00' %></td>
        <td class="r" style="font-weight:700;"><%= Math.abs(m.saldo).toLocaleString('es-CO',{minimumFractionDigits:2}) %> <%= m.saldo >= 0 ? 'D' : 'C' %></td>
      </tr>
    <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4">Totales</td>
        <td class="r"><%= movimientos.reduce((a,m)=>a+Number(m.debito),0).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r"><%= movimientos.reduce((a,m)=>a+Number(m.credito),0).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r">
          <% const saldoFinal = movimientos.length ? movimientos[movimientos.length-1].saldo : saldoInicial; %>
          <%= Math.abs(saldoFinal).toLocaleString('es-CO',{minimumFractionDigits:2}) %> <%= saldoFinal >= 0 ? 'D' : 'C' %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
<% } else { %>
<div class="erp-totales-bar">Selecciona una cuenta para ver su auxiliar.</div>
<% } %>

<style>
@media print { .erp-search-panel, .erp-actions, nav, .erp-tabs { display:none; } }
</style>
<%- include('../partials/footer') %>
