<%- include('../partials/header') %>
<%- include('../partials/erp-header', { icon: '📋', title: 'Plan de Cuentas — PUC' }) %>

<div class="erp-search-panel">
  <div class="erp-search-panel-title">Información de la empresa</div>
  <div class="erp-search-body">
    <div class="erp-search-row">
      <label>Empresa</label>
      <div class="erp-field-wrap">
        <span style="font-size:13px;">Inversiones Uniatlántico S.A.S. — NIT 900.123.456-7 — Empresa comercial</span>
      </div>
    </div>
    <div class="erp-search-row">
      <label>Cuentas activas</label>
      <div class="erp-field-wrap">
        <span style="font-size:13px;"><%= cuentas.length %> cuentas del Plan Único de Cuentas (PUC)</span>
      </div>
    </div>
  </div>
  <div class="erp-actions">
    <a href="/contabilidad" class="erp-btn erp-btn-outline"><span class="erp-btn-icon">←</span> Volver a libros</a>
    <button type="button" onclick="window.print()" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">🖨</span> Imprimir plan de cuentas</button>
  </div>
</div>

<div class="erp-items-table-wrap" style="padding:0;">
<table class="erp-book-table">
  <thead><tr>
    <th style="width:120px">Código</th>
    <th>Nombre de la cuenta</th>
    <th class="c" style="width:110px">Naturaleza</th>
    <th class="c" style="width:110px">Nivel</th>
  </tr></thead>
  <tbody>
  <% const nivelClass = { clase: 'erp-level-1', grupo: 'erp-level-2', cuenta: 'erp-level-3', subcuenta: 'erp-level-4' }; %>
  <% cuentas.forEach(c => { %>
    <tr class="<%= nivelClass[c.tipo] || '' %>">
      <td><code style="font-size:12px;"><%= c.codigo %></code></td>
      <td style="padding-left:<%= 10 + (c.codigo.length - 1) * 14 %>px"><%= c.nombre %></td>
      <td class="c">
        <span class="erp-badge-nat <%= c.naturaleza === 'D' ? 'deb' : 'cred' %>">
          <%= c.naturaleza === 'D' ? 'Débito' : 'Crédito' %>
        </span>
      </td>
      <td class="c" style="font-size:11px;color:var(--muted);text-transform:capitalize;"><%= c.tipo %></td>
    </tr>
  <% }) %>
  </tbody>
</table>
</div>

<%- include('../partials/footer') %>
