<%- include('../partials/header') %>
<%- include('../partials/erp-header', {
  icon: '📊', title: 'Estados financieros',
  tabs: [
    { label: 'Balance de prueba', href: '/contabilidad/balance-comprobacion', active: true },
    { label: 'Estado de situación financiera', href: '/contabilidad/estado-situacion', active: false },
    { label: 'Estado de resultado integral', href: '/contabilidad/estado-resultados', active: false },
  ]
}) %>

<div class="erp-search-panel">
  <div class="erp-search-panel-title">Opciones de búsqueda</div>
  <form method="GET" action="/contabilidad/balance-comprobacion">
    <div class="erp-search-body">
      <div class="erp-search-row">
        <label>Corte a fecha</label>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="hasta" value="<%= fechaHasta %>">
          <span class="erp-check">✓</span>
        </div>
      </div>
    </div>
    <div class="erp-actions">
      <button type="submit" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">⚙</span> Mostrar balance de prueba</button>
      <button type="button" onclick="window.print()" class="erp-btn erp-btn-teal"><span class="erp-btn-icon">🖨</span> Imprimir balance de prueba</button>
    </div>
  </form>
</div>

<div class="erp-totales-bar">
  <span>Suma débitos: <strong class="erp-amount-debit"><%= totales.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong></span>
  <span>Suma créditos: <strong class="erp-amount-credit"><%= totales.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong></span>
  <span class="<%= Math.abs(totales.debito - totales.credito) < 1 ? 'equilibrado' : 'desequilibrado' %>">
    <%= Math.abs(totales.debito - totales.credito) < 1 ? '✅ Partida doble cuadra' : '⚠ Diferencia: $' + Math.abs(totales.debito - totales.credito).toLocaleString('es-CO') %>
  </span>
</div>

<div class="erp-items-table-wrap" style="padding:0;">
<table class="erp-book-table">
  <thead>
    <tr>
      <th style="width:90px">Código</th>
      <th>Nombre de la cuenta</th>
      <th class="c" style="width:70px">Nat.</th>
      <th class="r" style="width:150px">Movimientos débito</th>
      <th class="r" style="width:150px">Movimientos crédito</th>
      <th class="r" style="width:150px">Saldo final</th>
    </tr>
  </thead>
  <tbody>
  <% let claseActual = ''; %>
  <% const nivelClass = { clase: 'erp-level-1', grupo: 'erp-level-2', cuenta: 'erp-level-3', subcuenta: 'erp-level-4' }; %>
  <% cuentas.forEach(c => { %>
    <% const claseNueva = c.codigo.substring(0,1); %>
    <% if(claseNueva !== claseActual){ claseActual = claseNueva; %>
    <tr>
      <td colspan="6" style="background:var(--erp-header-bg);color:#fff;font-weight:700;font-size:12px;letter-spacing:.05em;padding:6px 10px;">
        <% const nombreClase = {1:'ACTIVO',2:'PASIVO',3:'PATRIMONIO',4:'INGRESOS',5:'GASTOS',6:'COSTOS'}[claseNueva] || 'CLASE ' + claseNueva; %>
        CLASE <%= claseNueva %> — <%= nombreClase %>
      </td>
    </tr>
    <% } %>
    <tr class="<%= nivelClass[c.tipo] || '' %>">
      <td><code style="font-size:11px"><%= c.codigo %></code></td>
      <td style="padding-left:<%= 10 + Math.max(0,(c.codigo.length - 2)) * 12 %>px"><%= c.nombre %></td>
      <td class="c">
        <span class="erp-badge-nat <%= c.naturaleza==='D'?'deb':'cred' %>"><%= c.naturaleza %></span>
      </td>
      <td class="r erp-amount-debit"><%= Number(c.total_debito).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      <td class="r erp-amount-credit"><%= Number(c.total_credito).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      <td class="r" style="font-weight:<%= c.tipo==='subcuenta'?'700':'400' %>;">
        <%= Math.abs(c.saldo).toLocaleString('es-CO',{minimumFractionDigits:2}) %> <%= c.saldo >= 0 ? 'D' : 'C' %>
      </td>
    </tr>
  <% }) %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3">Gran total</td>
      <td class="r"><%= totales.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      <td class="r"><%= totales.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      <td class="r"></td>
    </tr>
  </tfoot>
</table>
</div>

<style>
@media print { .erp-search-panel, .erp-actions, nav, .erp-tabs { display:none; } }
</style>
<%- include('../partials/footer') %>
