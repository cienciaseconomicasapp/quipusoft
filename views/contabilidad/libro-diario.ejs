<%- include('../partials/header') %>
<%- include('../partials/erp-header', {
  icon: '📒', title: 'Libro Diario',
  tabs: [
    { label: 'Libro mayor', href: '/contabilidad/libro-mayor', active: false },
    { label: 'Libro diario', href: '/contabilidad/libro-diario', active: true },
  ]
}) %>

<div class="erp-search-panel">
  <div class="erp-search-panel-title">Opciones de búsqueda</div>
  <form method="GET" action="/contabilidad/libro-diario">
    <div class="erp-search-body">
      <div class="erp-search-row erp-row-split">
        <label>Fechas</label>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="desde" value="<%= fechaDesde %>">
          <span class="erp-check">✓</span>
        </div>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="hasta" value="<%= fechaHasta %>">
          <span class="erp-check">✓</span>
        </div>
      </div>
      <div class="erp-search-row">
        <label>Filtrar por cuenta</label>
        <div class="erp-field-wrap">
          <input class="erp-input" type="text" name="cuenta" value="<%= cuentaFiltro %>" placeholder="Ej: 1305, 4135, 24... (opcional)">
        </div>
      </div>
    </div>
    <div class="erp-actions">
      <button type="submit" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">🔎</span> Mostrar libro diario</button>
      <button type="button" onclick="window.print()" class="erp-btn erp-btn-teal"><span class="erp-btn-icon">🖨</span> Imprimir libro diario</button>
    </div>
  </form>
</div>

<div class="erp-totales-bar">
  <span>Asientos: <strong><%= asientos.length %></strong></span>
  <span>Total débitos: <strong class="erp-amount-debit">$<%= totales.debito.toLocaleString('es-CO') %></strong></span>
  <span>Total créditos: <strong class="erp-amount-credit">$<%= totales.credito.toLocaleString('es-CO') %></strong></span>
  <span class="<%= Math.abs(totales.debito - totales.credito) < 1 ? 'equilibrado' : 'desequilibrado' %>">
    <%= Math.abs(totales.debito - totales.credito) < 1 ? '✅ Partida doble cuadra' : '⚠ Diferencia: $' + Math.abs(totales.debito - totales.credito).toLocaleString('es-CO') %>
  </span>
</div>

<% asientos.forEach(a => { %>
  <div class="erp-book-section">
    <div class="erp-book-section-title">
      <span class="comprobante"><%= a.numero_comprobante %></span>
      <span class="fecha"><%= new Date(a.fecha).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}) %></span>
      <span class="tipo-badge"><%= a.tipo_comprobante %></span>
      <% if(a.es_caso_atipico){ %><span class="atipico-badge">⚠ Caso <%= a.codigo_caso %></span><% } %>
      <% if(a.estado === 'corregido'){ %><span class="corregido-badge">✅ Corregido</span><% } %>
      <% if(a.estado === 'ajuste'){ %><span class="ajuste-badge">🔧 Asiento de ajuste</span><% } %>
      <% if(a.es_caso_atipico && a.estado !== 'corregido' && a.estado !== 'ajuste'){ %>
        <a href="/contabilidad/ajuste/<%= a.id %>" class="erp-btn erp-btn-blue" style="padding:3px 10px;font-size:11px;">✏ Registrar ajuste</a>
      <% } %>
      <span style="font-weight:400;font-size:12.5px;color:var(--muted);">
        — <%= a.concepto %> — <%= a.contraparte %>
      </span>
    </div>
    <% if(a.es_caso_atipico && a.nota_pedagogica){ %>
      <div class="nota-ped" style="margin-bottom:6px;">📌 <%= a.nota_pedagogica %></div>
    <% } %>
    <table class="erp-book-table">
      <thead><tr>
        <th style="width:100px">Código cuenta</th>
        <th>Nombre cuenta</th>
        <th class="r" style="width:150px">Débito</th>
        <th class="r" style="width:150px">Crédito</th>
      </tr></thead>
      <tbody>
      <% JSON.parse(JSON.stringify(a.detalles)).forEach(d => { %>
        <tr>
          <td><code><%= d.cuenta_codigo %></code></td>
          <td><%= d.cuenta_nombre %><% if(d.descripcion && d.descripcion !== d.cuenta_nombre){ %> — <span style="color:var(--muted);"><%= d.descripcion %></span><% } %></td>
          <td class="r <%= d.debito > 0 ? 'erp-amount-debit' : '' %>"><%= d.debito > 0 ? d.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) : '0.00' %></td>
          <td class="r <%= d.credito > 0 ? 'erp-amount-credit' : '' %>"><%= d.credito > 0 ? d.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) : '0.00' %></td>
        </tr>
      <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2">Totales</td>
          <td class="r"><%= Number(a.total_debito).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
          <td class="r"><%= Number(a.total_credito).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
<% }) %>

<style>
.comprobante { font-family:monospace; font-weight:700; }
.fecha { font-size:12px; color:var(--muted); font-weight:400; }
.tipo-badge { font-size:11px; background:var(--erp-row-hover); color:var(--erp-header-bg); padding:2px 8px; border-radius:10px; font-weight:600; }
.atipico-badge { font-size:11px; background:#FDEBD0; color:#784212; padding:2px 8px; border-radius:10px; font-weight:600; }
.corregido-badge { font-size:11px; background:#D5E8D4; color:#1E5631; padding:2px 8px; border-radius:10px; font-weight:600; }
.ajuste-badge { font-size:11px; background:var(--erp-row-hover); color:var(--erp-header-bg); padding:2px 8px; border-radius:10px; font-weight:600; }
.nota-ped { font-size:12px; background:#FFF3CD; border-left:3px solid #F0AD4E; padding:4px 10px; border-radius:0 4px 4px 0; color:#7D4900; }
@media print { .erp-search-panel, .erp-actions, nav, .erp-tabs { display:none; } }
</style>

<%- include('../partials/footer') %>
