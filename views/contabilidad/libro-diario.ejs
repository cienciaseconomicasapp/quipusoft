<%- include('../partials/header') %>
<%- include('../partials/erp-header', {
  icon: '📒', title: 'Libro Diario',
  tabs: [
    { label: 'Libro mayor', href: '/contabilidad/libro-mayor', active: false },
    { label: 'Libro diario', href: '/contabilidad/libro-diario', active: true },
  ]
}) %>

<% if(error && error.length){ %><div class="alert alert-error"><%= error %></div><% } %>

<!-- FILTROS -->
<div class="erp-search-panel">
  <form method="GET" action="/contabilidad/libro-diario" class="erp-search-form">
    <div class="erp-search-row">
      <label>Fechas</label>
      <div class="erp-field-wrap valid">
        <input class="erp-input" type="date" name="desde" value="<%= fechaDesde %>">
        <span style="padding:0 4px;color:var(--muted);">—</span>
        <input class="erp-input" type="date" name="hasta" value="<%= fechaHasta %>">
        <span class="erp-check">✓</span>
      </div>
      <label>Nivel de cuentas</label>
      <div class="erp-field-wrap valid">
        <select class="erp-select" name="nivel">
          <option value="clase"      <%= nivelFiltro==='clase'      ?'selected':'' %>>Clase (1 dígito)</option>
          <option value="grupo"      <%= nivelFiltro==='grupo'      ?'selected':'' %>>Grupo (2 dígitos)</option>
          <option value="cuenta"     <%= nivelFiltro==='cuenta'     ?'selected':'' %>>Cuenta (4 dígitos)</option>
          <option value="subcuenta"  <%= nivelFiltro==='subcuenta'  ?'selected':'' %>>Subcuenta (6 dígitos)</option>
          <option value="auxiliar"   <%= nivelFiltro==='auxiliar'   ?'selected':'' %>>Auxiliar (8 dígitos)</option>
        </select>
        <span class="erp-check">✓</span>
      </div>
      <button type="submit" class="erp-btn erp-btn-blue">🔎 Mostrar libro diario</button>
      <button type="button" onclick="window.print()" class="erp-btn erp-btn-outline">🖨 Imprimir</button>
    </div>
  </form>
</div>

<div class="erp-totales-bar">
  <span>Tipos de documento: <strong><%= resumen.length %></strong></span>
  <span>Total documentos: <strong><%= totales.documentos %></strong></span>
  <span>Total débitos: <strong class="erp-amount-debit">$<%= totales.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong></span>
  <span>Total créditos: <strong class="erp-amount-credit">$<%= totales.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong></span>
  <span class="<%= Math.abs(totales.debito - totales.credito) < 1 ? 'equilibrado' : 'desequilibrado' %>">
    <%= Math.abs(totales.debito - totales.credito) < 1 ? '✅ Partida doble cuadra' : '⚠ Diferencia: $' + Math.abs(totales.debito - totales.credito).toLocaleString('es-CO') %>
  </span>
</div>

<% if(resumen.length === 0) { %>
  <div style="padding:2rem;text-align:center;color:var(--muted);">
    No hay movimientos en el período seleccionado.
  </div>
<% } else { %>

<% resumen.forEach(tipo => { %>
<div class="erp-book-section">
  <div class="erp-book-section-title" style="display:flex;justify-content:space-between;align-items:center;">
    <span>
      <%= tipo.tipo %>
      <span style="font-weight:400;font-size:12px;color:var(--muted);margin-left:8px;">
        <%= tipo.num_documentos %> documento<%= tipo.num_documentos!==1?'s':'' %>
        &nbsp;|&nbsp; <%= new Date(tipo.fecha_desde).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'numeric'}) %>
        <% if(tipo.fecha_desde !== tipo.fecha_hasta) { %>
          — <%= new Date(tipo.fecha_hasta).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'numeric'}) %>
        <% } %>
      </span>
    </span>
    <span style="font-size:13px;">
      D: <strong class="erp-amount-debit">$<%= tipo.total_debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong>
      &nbsp; C: <strong class="erp-amount-credit">$<%= tipo.total_credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong>
    </span>
  </div>
  <table class="erp-book-table">
    <thead><tr>
      <th style="width:120px">Código (<%= nivelFiltro %>)</th>
      <th>Nombre cuenta</th>
      <th class="r" style="width:160px">Débito (+)</th>
      <th class="r" style="width:160px">Crédito (−)</th>
      <th class="r" style="width:160px">Saldo</th>
    </tr></thead>
    <tbody>
    <% tipo.cuentas.forEach(cta => { %>
      <tr>
        <td><code style="font-size:11px;"><%= cta.codigo %></code></td>
        <td><%= cta.nombre %></td>
        <td class="r erp-amount-debit"><%= cta.debito > 0 ? cta.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) : '' %></td>
        <td class="r erp-amount-credit"><%= cta.credito > 0 ? cta.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) : '' %></td>
        <td class="r" style="font-weight:600;color:<%= cta.saldo >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>">
          <%= cta.saldo.toLocaleString('es-CO',{minimumFractionDigits:2}) %>
        </td>
      </tr>
    <% }) %>
    </tbody>
    <tfoot>
      <tr style="font-weight:700;background:var(--gray);">
        <td colspan="2">Total <%= tipo.tipo %></td>
        <td class="r erp-amount-debit"><%= tipo.total_debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r erp-amount-credit"><%= tipo.total_credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r" style="color:<%= Math.abs(tipo.total_debito-tipo.total_credito)<1?'var(--erp-check-green)':'var(--red)' %>">
          <%= (tipo.total_debito - tipo.total_credito).toLocaleString('es-CO',{minimumFractionDigits:2}) %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
<% }) %>

<!-- TOTALES GENERALES -->
<div class="erp-book-section" style="background:var(--erp-header-bg);color:#fff;border-radius:8px;">
  <div class="erp-book-section-title" style="color:#fff;">Totales generales — <%= fechaDesde %> al <%= fechaHasta %></div>
  <table class="erp-book-table" style="color:#fff;">
    <thead><tr>
      <th colspan="2">Concepto</th>
      <th class="r">Débito</th>
      <th class="r">Crédito</th>
      <th class="r">Saldo neto</th>
    </tr></thead>
    <tbody>
    <% resumen.forEach(t => { %>
      <tr>
        <td colspan="2"><%= t.tipo %> (<%= t.num_documentos %> docs.)</td>
        <td class="r">$<%= t.total_debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r">$<%= t.total_credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r">$<%= (t.total_debito - t.total_credito).toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      </tr>
    <% }) %>
    </tbody>
    <tfoot>
      <tr style="font-size:15px;font-weight:700;border-top:2px solid rgba(255,255,255,0.3);">
        <td colspan="2">TOTAL GENERAL (<%= totales.documentos %> documentos)</td>
        <td class="r">$<%= totales.debito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r">$<%= totales.credito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r" style="color:<%= Math.abs(totales.debito-totales.credito)<1?'#A8E6CF':'#FFB3B3' %>">
          $<%= (totales.debito - totales.credito).toLocaleString('es-CO',{minimumFractionDigits:2}) %>
          <%= Math.abs(totales.debito-totales.credito)<1?'✓':'✗' %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>

<% } %>

<style>
@media print { .erp-search-panel, .erp-actions, nav, .erp-tabs { display:none; } }
</style>
<%- include('../partials/footer') %>
