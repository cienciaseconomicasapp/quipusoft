<%- include('../partials/header') %>
<%- include('../partials/erp-header', {
  icon: '📗', title: 'Libro Mayor',
  tabs: [
    { label: 'Libro mayor', href: '/contabilidad/libro-mayor', active: true },
    { label: 'Libro diario', href: '/contabilidad/libro-diario', active: false },
  ]
}) %>

<div class="erp-search-panel">
  <div class="erp-search-panel-title">Opciones de búsqueda</div>
  <form method="GET" action="/contabilidad/libro-mayor">
    <div class="erp-search-body">
      <div class="erp-search-row erp-row-split">
        <label>Fechas</label>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="desde" value="<%= fechaDesde %>">
          <span class="erp-check">✓</span>
        </div>
        <div class="erp-field-wrap valid">
          <input class="erp-input" type="date" name="hasta" value="<%= fechaHasta %>">
          <span class="erp-check">✓</span>
        </div>
      </div>
      <div class="erp-search-row">
        <label>Filtrar cuentas (prefijo)</label>
        <div class="erp-field-wrap">
          <input class="erp-input" type="text" name="cuenta" value="<%= cuentaFiltro %>" placeholder="Ej: 11, 4135, 5105... (opcional)">
        </div>
      </div>
    </div>
    <div class="erp-actions">
      <button type="submit" class="erp-btn erp-btn-blue"><span class="erp-btn-icon">🔎</span> Mostrar libro mayor</button>
      <button type="button" onclick="window.print()" class="erp-btn erp-btn-teal"><span class="erp-btn-icon">🖨</span> Imprimir libro mayor</button>
      <a href="/exportar/libro-mayor?desde=<%= fechaDesde %>&hasta=<%= fechaHasta %>" class="erp-btn erp-btn-outline" style="background:#1F7540;color:#fff;border-color:#1F7540;">📥 Exportar Excel</a>
    </div>
  </form>
</div>

<% if(mayor.length === 0){ %>
  <div class="erp-totales-bar">No hay movimientos para el período y filtro seleccionados.</div>
<% } else { %>

<!-- RESUMEN GENERAL -->
<div class="erp-book-section">
  <div class="erp-book-section-title">Resumen de saldos por cuenta</div>
  <div class="erp-items-table-wrap" style="padding:0;">
  <table class="erp-book-table">
    <thead><tr>
      <th style="width:90px">Código</th>
      <th>Nombre cuenta</th>
      <th class="r">Saldo inicial</th>
      <th class="r">Movimientos débito</th>
      <th class="r">Movimientos crédito</th>
      <th class="r">Saldo final</th>
    </tr></thead>
    <tbody>
    <% let sumaSaldos = 0; %>
    <% mayor.forEach(c => { %>
      <% const sf = (c.saldoInicial || 0) + c.totDebito - c.totCredito; sumaSaldos += sf; %>
      <tr>
        <td><a href="#cuenta-<%= c.codigo %>"><code><%= c.codigo %></code></a></td>
        <td><%= c.nombre %></td>
        <td class="r" style="color:<%= (c.saldoInicial||0) >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>">
          <%= (c.saldoInicial||0).toLocaleString('es-CO',{minimumFractionDigits:2}) %>
        </td>
        <td class="r erp-amount-debit"><%= c.totDebito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r erp-amount-credit"><%= c.totCredito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r" style="font-weight:700;color:<%= sf >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>">
          <%= sf.toLocaleString('es-CO',{minimumFractionDigits:2}) %>
        </td>
      </tr>
    <% }) %>
    </tbody>
    <tfoot>
      <tr style="background:var(--erp-header-bg);color:#fff;font-weight:700;">
        <td colspan="5" style="text-align:right;">Suma de saldos (debe ser 0)</td>
        <td class="r" style="color:<%= Math.abs(sumaSaldos) < 1 ? '#A8E6CF' : '#FFB3B3' %>">
          <%= sumaSaldos.toLocaleString('es-CO',{minimumFractionDigits:2}) %>
          <%= Math.abs(sumaSaldos) < 1 ? '✓' : '✗' %>
        </td>
      </tr>
    </tfoot>
  </table>
  </div>
</div>

<!-- DETALLE POR CUENTA -->
<% mayor.forEach(c => { %>
<% const sf = (c.saldoInicial || 0) + c.totDebito - c.totCredito; %>
<div class="erp-book-section" id="cuenta-<%= c.codigo %>">
  <div class="erp-book-section-title">
    <code><%= c.codigo %></code> <%= c.nombre %>
    <span style="font-weight:400;font-size:12.5px;color:var(--muted);">
      — Saldo inicial: <strong style="color:<%= (c.saldoInicial||0) >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>"><%= (c.saldoInicial||0).toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong>
      &nbsp;|&nbsp; Saldo final: <strong style="color:<%= sf >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>"><%= sf.toLocaleString('es-CO',{minimumFractionDigits:2}) %></strong>
    </span>
  </div>
  <table class="erp-book-table">
    <thead><tr>
      <th style="width:90px">Fecha</th>
      <th style="width:120px">Comprobante</th>
      <th>Concepto / Contraparte</th>
      <th class="r" style="width:140px">Débito (+)</th>
      <th class="r" style="width:140px">Crédito (−)</th>
    </tr></thead>
    <tbody>
    <tr style="background:var(--gray);font-style:italic;font-size:12px;">
      <td colspan="3">Saldo inicial al <%= fechaDesde %></td>
      <td class="r" colspan="2" style="font-weight:600;color:<%= (c.saldoInicial||0) >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>">
        <%= (c.saldoInicial||0).toLocaleString('es-CO',{minimumFractionDigits:2}) %>
      </td>
    </tr>
    <% c.movimientos.forEach(m => { %>
      <tr>
        <td><%= new Date(m.fecha).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'2-digit'}) %></td>
        <td><code style="font-size:11px"><%= m.numero_comprobante %></code></td>
        <td><%= m.descripcion || m.concepto %><% if(m.contraparte){ %> <span style="color:var(--muted);">— <%= m.contraparte %></span><% } %></td>
        <td class="r <%= m.debito > 0 ? 'erp-amount-debit' : '' %>"><%= m.debito > 0 ? Number(m.debito).toLocaleString('es-CO',{minimumFractionDigits:2}) : '' %></td>
        <td class="r <%= m.credito > 0 ? 'erp-amount-credit' : '' %>"><%= m.credito > 0 ? Number(m.credito).toLocaleString('es-CO',{minimumFractionDigits:2}) : '' %></td>
      </tr>
    <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3">Totales del período</td>
        <td class="r erp-amount-debit"><%= c.totDebito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
        <td class="r erp-amount-credit"><%= c.totCredito.toLocaleString('es-CO',{minimumFractionDigits:2}) %></td>
      </tr>
      <tr style="font-weight:700;">
        <td colspan="4">Saldo final</td>
        <td class="r" style="color:<%= sf >= 0 ? 'var(--erp-check-green)' : 'var(--red)' %>">
          <%= sf.toLocaleString('es-CO',{minimumFractionDigits:2}) %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
<% }) %>

<% } %>

<style>
@media print { .erp-search-panel, .erp-actions, nav, .erp-tabs { display:none; } }
</style>
<%- include('../partials/footer') %>
