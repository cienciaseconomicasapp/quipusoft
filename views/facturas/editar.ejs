<%- include('../partials/header', {title: title}) %>
<div class="page-header">
  <h2>Editar transacción: <%= transaccion.documento %></h2>
</div>

<% if(error && error.length){ %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="form-card">
  <form method="POST" action="/transacciones/<%= transaccion.id %>/editar">
    <div class="form-group">
      <label>Concepto</label>
      <input type="text" name="concepto" value="<%= transaccion.concepto %>" required>
    </div>
    <div class="form-group">
      <label>Tipo de IVA</label>
      <select name="tipo_iva">
        <option value="gravado" <%= transaccion.tipo_iva==='gravado'?'selected':'' %>>Gravado (19%)</option>
        <option value="exento" <%= transaccion.tipo_iva==='exento'?'selected':'' %>>Exento (0%)</option>
        <option value="excluido" <%= transaccion.tipo_iva==='excluido'?'selected':'' %>>Excluido</option>
      </select>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>Subtotal</label>
        <input type="number" id="subtotal" name="subtotal" value="<%= transaccion.subtotal %>" required>
      </div>
      <div class="form-group">
        <label>IVA</label>
        <input type="number" id="iva" name="iva" value="<%= transaccion.iva %>">
      </div>
      <div class="form-group">
        <label>Retención</label>
        <input type="number" id="retencion" name="retencion" value="<%= transaccion.retencion %>">
      </div>
      <div class="form-group">
        <label>Total calculado</label>
        <div id="total_calculado" style="padding:8px 12px;background:var(--gray);border-radius:6px;font-weight:600;font-size:14px;">$0</div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:1rem;">
      <button type="submit" class="btn btn-primary">Guardar cambios</button>
      <a href="/transacciones/<%= transaccion.id %>" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
