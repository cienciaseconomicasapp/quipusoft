<%- include('../partials/header', {title: title}) %>
<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
  <div>
    <h2>Transacción: <%= transaccion.documento %></h2>
    <p><%= transaccion.tipo %> &nbsp;|&nbsp; <%= new Date(transaccion.fecha).toLocaleDateString('es-CO') %></p>
  </div>
  <a href="/transacciones" class="btn btn-secondary">Volver</a>
</div>

<% if(transaccion.es_caso_atipico && transaccion.notas_pedagogicas){ %>
<div style="background:#FCF3CF;border-left:4px solid #F39C12;padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:1.5rem;">
  <strong style="color:#7D4900;">⚠ Caso pedagógico <%= transaccion.codigo_caso %></strong><br>
  <span style="font-size:13px;color:#7D4900;"><%= transaccion.notas_pedagogicas %></span>
</div>
<% } %>

<% if(transaccion.estado === 'rechazada'){ %>
<div style="background:#FADBD8;border-left:4px solid var(--red);padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:1.5rem;">
  <strong style="color:var(--red);">✗ Factura RECHAZADA por la autoridad tributaria</strong><br>
  <span style="font-size:13px;color:var(--red);">Esta factura fue rechazada. Debe emitir una nota crédito y reexpedir la factura corregida.</span>
</div>
<% } %>

<div class="form-card">
  <h3>Datos de la transacción</h3>
  <div class="info-grid">
    <div><span>Documento</span><strong><%= transaccion.documento %></strong></div>
    <div><span>Fecha</span><strong><%= new Date(transaccion.fecha).toLocaleDateString('es-CO') %></strong></div>
    <div><span>Tipo</span><strong><%= transaccion.tipo %></strong></div>
    <div><span>Contraparte</span><strong><%= transaccion.contraparte_nombre %></strong></div>
    <div><span>Concepto</span><strong><%= transaccion.concepto %></strong></div>
    <div><span>Tipo IVA</span><strong><%= transaccion.tipo_iva %></strong></div>
    <div><span>Estado</span><strong><span class="badge badge-<%= transaccion.estado %>"><%= transaccion.estado %></span></strong></div>
    <div><span>Mes</span><strong><%= ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'][transaccion.mes-1] %> 2025</strong></div>
  </div>
</div>

<div class="form-card" style="margin-top:1rem;">
  <h3>Valores</h3>
  <div style="display:grid;gap:8px;">
    <div style="display:grid;grid-template-columns:1fr auto;padding:8px 0;border-bottom:1px solid var(--border);font-size:14px;">
      <span>Subtotal (base)</span><strong>$<%= Number(transaccion.subtotal).toLocaleString('es-CO') %></strong>
    </div>
    <div style="display:grid;grid-template-columns:1fr auto;padding:8px 0;border-bottom:1px solid var(--border);font-size:14px;">
      <span>IVA</span><strong>$<%= Number(transaccion.iva).toLocaleString('es-CO') %></strong>
    </div>
    <div style="display:grid;grid-template-columns:1fr auto;padding:8px 0;border-bottom:1px solid var(--border);font-size:14px;">
      <span>Retención en la fuente</span><strong style="color:var(--red)">$<%= Number(transaccion.retencion).toLocaleString('es-CO') %></strong>
    </div>
    <div style="display:grid;grid-template-columns:1fr auto;padding:10px 12px;background:var(--blue-light);border-radius:4px;font-size:16px;font-weight:700;">
      <span>Total</span><strong>$<%= Number(transaccion.total).toLocaleString('es-CO') %></strong>
    </div>
  </div>
</div>

<div style="margin-top:1rem;display:flex;gap:8px;">
  <% if(transaccion.editable){ %>
    <a href="/transacciones/<%= transaccion.id %>/editar" class="btn btn-primary">Editar</a>
  <% } %>
  <a href="/transacciones" class="btn btn-secondary">Volver al libro</a>
</div>
<%- include('../partials/footer') %>
