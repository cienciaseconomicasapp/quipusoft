<%- include('../partials/header') %>

<div class="page-header">
  <h2>🏆 Ranking de evaluaciones</h2>
  <p>Ranking por semana (mejor puntaje de cada estudiante) y ranking global (suma de mejores puntajes por semana).</p>
</div>

<% if (user.rol === 'estudiante') { %>
  <div class="alert-panel">
    <div class="alert-item" style="background: var(--blue-light); color: var(--blue);">
      <% if (miPosicionGlobal) { %>
        Tu posición en el ranking global: <strong>#<%= miPosicionGlobal %></strong> de <%= rankingGlobal.length %> estudiantes.
      <% } else { %>
        Aún no apareces en el ranking global — realiza al menos una evaluación.
      <% } %>
    </div>
  </div>
<% } %>

<% if (user.rol === 'docente' || user.rol === 'admin') {
  const _codigoDesactualizado = (typeof estudiantes === 'undefined');
  const _estudiantes = _codigoDesactualizado ? [] : estudiantes;
%>
  <div class="form-card">
    <h3>🔄 Resetear evaluaciones de un estudiante</h3>
    <p style="font-size:12px; color: var(--muted); margin-bottom: 1rem;">
      Usa esta opción si un estudiante quedó con una calificación incorrecta por un error técnico (por ejemplo, respuestas mal registradas). Al resetear, se eliminan sus intentos de la semana seleccionada (o de todas) y el estudiante podrá volver a presentar la evaluación desde cero. Esta acción no se puede deshacer.
    </p>
    <form action="/evaluaciones/admin/resetear-intentos" method="POST" onsubmit="return confirm('¿Seguro que quieres eliminar los intentos seleccionados? Esta acción no se puede deshacer.');">
      <div class="form-grid">
        <div class="form-group">
          <label>Estudiante</label>
          <select name="usuario_id" required>
            <option value="">Selecciona un estudiante...</option>
            <% _estudiantes.forEach(e => { %>
              <option value="<%= e.id %>">
                <%= e.nombre %> — <%= e.email %>
                <% if (e.semanas_con_intentos && e.semanas_con_intentos.length) { %>
                  (semanas con intentos: <%= e.semanas_con_intentos.join(', ') %>)
                <% } else { %>
                  (sin intentos registrados)
                <% } %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Semana a resetear</label>
          <select name="semana" required>
            <option value="1">Semana 1</option>
            <option value="2">Semana 2</option>
            <option value="3">Semana 3</option>
            <option value="4">Semana 4</option>
            <option value="todas">Todas las semanas</option>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-danger" style="margin-top:1rem;">Resetear evaluación(es)</button>
    </form>
    <% if (_codigoDesactualizado) { %>
      <p style="font-size:11px; color: var(--muted); margin-top: 0.5rem;">
        (No se cargó la lista de estudiantes — verifica que el servidor esté actualizado con la última versión de <code>src/routes/evaluaciones.js</code>.)
      </p>
    <% } else if (!_estudiantes.length) { %>
      <p style="font-size:11px; color: var(--muted); margin-top: 0.5rem;">
        (No hay estudiantes registrados con rol "estudiante" todavía.)
      </p>
    <% } %>
  </div>
<% } %>


<div class="quick-links">
  <h3>Filtrar por semana</h3>
  <div class="links-grid">
    <a href="/evaluaciones/ranking" class="quick-link <%= !semanaFiltro ? 'accent' : '' %>">Todas</a>
    <% [1,2,3,4].forEach(s => { %>
      <a href="/evaluaciones/ranking?semana=<%= s %>" class="quick-link <%= semanaFiltro===s ? 'accent' : '' %>">Semana <%= s %></a>
    <% }) %>
  </div>
</div>

<% [1,2,3,4].forEach(semana => { %>
  <% if (rankingPorSemana[semana]) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th colspan="4" style="background: var(--blue);">Semana <%= semana %></th>
          </tr>
          <tr>
            <th>Posición</th>
            <th>Estudiante</th>
            <th>Puntaje</th>
            <th>Aciertos</th>
          </tr>
        </thead>
        <tbody>
          <% if (rankingPorSemana[semana].length === 0) { %>
            <tr><td colspan="4" class="text-center" style="color: var(--muted);">Aún no hay intentos registrados.</td></tr>
          <% } %>
          <% rankingPorSemana[semana].forEach((r, idx) => { %>
            <tr style="<%= (user.rol==='estudiante' && r.usuario_id===user.id) ? 'background: var(--blue-light); font-weight:600;' : '' %>">
              <td>
                <% if (idx===0) { %>🥇<% } else if (idx===1) { %>🥈<% } else if (idx===2) { %>🥉<% } else { %><%= idx+1 %>º<% } %>
              </td>
              <td><%= r.nombre %><%= (r.usuario_id===user.id) ? ' (tú)' : '' %></td>
              <td><%= parseFloat(r.mejor_puntaje).toFixed(2) %></td>
              <td><%= r.correctas %> / <%= r.total_preguntas %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
<% }) %>

<% if (!semanaFiltro) { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th colspan="4" style="background: var(--green);">Ranking global (suma de mejores puntajes por semana)</th>
        </tr>
        <tr>
          <th>Posición</th>
          <th>Estudiante</th>
          <th>Puntaje acumulado</th>
          <th>Semanas realizadas</th>
        </tr>
      </thead>
      <tbody>
        <% if (rankingGlobal.length === 0) { %>
          <tr><td colspan="4" class="text-center" style="color: var(--muted);">Aún no hay datos de ranking global.</td></tr>
        <% } %>
        <% rankingGlobal.forEach((r, idx) => { %>
          <tr style="<%= (user.rol==='estudiante' && r.usuario_id===user.id) ? 'background: var(--green-light); font-weight:600;' : '' %>">
            <td>
              <% if (idx===0) { %>🥇<% } else if (idx===1) { %>🥈<% } else if (idx===2) { %>🥉<% } else { %><%= idx+1 %>º<% } %>
            </td>
            <td><%= r.nombre %><%= (r.usuario_id===user.id) ? ' (tú)' : '' %></td>
            <td><%= r.total.toFixed(2) %> / <%= (r.semanas_realizadas * 100).toFixed(0) %></td>
            <td><%= r.semanas_realizadas %> / 4</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
